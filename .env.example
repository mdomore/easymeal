# EasyMeal Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# For Supabase: Use your Supabase PostgreSQL connection string
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.supabase.co:5432/postgres

# Supabase Configuration
# Get these from your Supabase project settings (API settings)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase Storage
SUPABASE_BUCKET=photos

# Application Configuration
ENVIRONMENT=development
# Optional: Additional CORS origins (comma-separated)
# CORS_ORIGINS=https://example.com,https://another-domain.com

# For Docker Compose (if using local Supabase)
# SUPABASE_POSTGRES_PASSWORD=your_postgres_password
# SECRET_KEY=your_secret_key_here
