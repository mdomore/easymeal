# EasyMeal Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# For Supabase: Use your Supabase PostgreSQL connection string
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.supabase.co:5432/postgres

# Supabase Configuration
# Get these from your Supabase project settings (API settings)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase Storage
SUPABASE_BUCKET=photos

# Application Configuration
ENVIRONMENT=development

# CORS Configuration (Optional)
# Only needed if you're deploying to a specific domain and accessing from a different origin
# For local development, defaults (localhost:8000, localhost:3000) are already included
# For production with a custom domain, add your domain(s) here:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# 
# Note: If you're running the app directly (not behind a proxy), you may not need this.
# Only set if you get CORS errors when accessing the API from your frontend domain.

# For Docker Compose (if using local Supabase)
# SUPABASE_POSTGRES_PASSWORD=your_postgres_password
# SECRET_KEY=your_secret_key_here
